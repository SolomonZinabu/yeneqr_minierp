              >
                <Button
                  onClick={() => setScreen('menu')}
                  size="lg"
                  className="w-full h-14 text-lg font-semibold rounded-2xl bg-[#039D55] hover:bg-[#0E5433] text-white shadow-lg shadow-[#039D55]/25 active:scale-[0.98] transition-all"
                >
                  {tuiGlobal('menu.start_ordering', 'Start Ordering')}
                </Button>
              </motion.div>

              <motion.p
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ delay: 0.8 }}
                className="text-xs text-muted-foreground mt-4 text-center"
              >
                {tuiGlobal('menu.order_from_table', 'Order directly from your table')}
              </motion.p>
            </div>
          </motion.div>
        )

      case 'menu':
        return (
          <div className="flex flex-col h-screen bg-background">
            {/* Header */}
            <div className="sticky top-0 z-20 bg-background/95 backdrop-blur-sm border-b border-border">
              <div className="flex items-center justify-between px-4 py-3">
                <div>
                  <h1 className="text-lg font-bold">
                    {tName(restaurant.name, restaurant.nameAm, restaurant.nameI18n)}
                  </h1>
                  <div className="flex items-center gap-2">
                    <p className="text-xs text-muted-foreground">
                      {tuiGlobal('menu.table', 'Table')} {table?.number} • {tName(branch?.name || '', branch?.nameAm || null, branch?.nameI18n)}
                    </p>
                    {loyaltyPoints > 0 && (
                      <span className="inline-flex items-center gap-1 text-[10px] font-medium text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded-full">
                        <Gift className="w-3 h-3" />
                        {loyaltyPoints} {tuiGlobal('menu.pts', 'pts')}
                      </span>
                    )}
                  </div>
                </div>
                <div className="flex items-center gap-2">
                  <button
                    onClick={() => setScreen('order')}
                    className="w-9 h-9 rounded-full bg-muted flex items-center justify-center relative"
                  >
                    <ClipboardList className="w-4 h-4" />
                    {currentOrder && (
                      <span className="absolute -top-1 -right-1 w-4 h-4 bg-[#039D55] text-white text-[10px] font-bold rounded-full flex items-center justify-center">1</span>
                    )}
                  </button>
                  {enabledLanguages.length > 0 ? (
                    <LanguagePicker
                      language={language}
                      languages={enabledLanguages}
                      onChange={setLanguage}
                    />
                  ) : (
                    <button
                      onClick={() => setLanguage(language === 'en' ? 'am' : 'en')}
                      className="flex items-center gap-1 px-3 py-1.5 rounded-full bg-secondary text-sm font-medium active:scale-95 transition-transform"
                    >
                      <Globe className="w-3.5 h-3.5" />
                      {language === 'en' ? 'አማ' : 'EN'}
                    </button>
                  )}
                </div>
              </div>

              {/* Promotions Banner - Auto-scrolling */}
              {promotions.length > 0 && (
