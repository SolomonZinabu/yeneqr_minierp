                className="flex items-center gap-2 text-sm text-muted-foreground mb-12"
              >
                <span className="flex items-center gap-1">
                  <span className="w-2 h-2 rounded-full bg-[#039D55] animate-pulse" />
                  {tuiGlobal('menu.table', 'Table')} {table?.number}
                </span>
                <span>•</span>
                <span>{tName(branch?.name || 'Main Branch', branch?.nameAm || null, branch?.nameI18n)}</span>
              </motion.div>

              <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.6 }}
