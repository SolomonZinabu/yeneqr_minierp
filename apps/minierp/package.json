{
  "name": "mini-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env --override -- next dev -p 3100",
    "build": "dotenv -e .env --override -- next build",
    "start": "dotenv -e .env --override -- next start -p 3100",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenv -e .env --override -- prisma generate",
    "db:push": "dotenv -e .env --override -- prisma db push",
    "db:migrate": "dotenv -e .env --override -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env --override -- prisma migrate deploy",
    "db:migrate:status": "dotenv -e .env --override -- prisma migrate status",
    "db:reset": "dotenv -e .env --override -- prisma migrate reset",
    "db:studio": "dotenv -e .env --override -- prisma studio",
    "db:start": "node scripts/start-embedded-postgres.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.82.0",
    "better-auth": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embedded-postgres": "^18.4.0-beta.17",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.1",
    "postcss": "^8.4.49",
    "prisma": "^6.11.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
